<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Pacifico&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  overflow: hidden;
  color: white;
}

/* LOCK SCREEN */
#lockScreen {
  position: fixed;
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #ff758c, #ff7eb3);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  z-index: 10;
}

#lockScreen input {
  padding: 10px;
  border-radius: 20px;
  border: none;
  margin-top: 10px;
}

#lockScreen button {
  margin-top: 10px;
  padding: 10px 20px;
  border-radius: 20px;
  border: none;
  background: white;
  color: #ff4b7d;
  font-weight: bold;
}

/* slides */
.slide {
  position: absolute;
  width: 100%;
  height: 100vh;
  display: none;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  padding: 20px;
  text-align: center;
}

/* pink theme */
.slide:nth-of-type(1) { background: linear-gradient(135deg, #ff758c, #ff7eb3); }
.slide:nth-of-type(2) { background: linear-gradient(135deg, #ff7eb3, #ff758c); }
.slide:nth-of-type(3) { background: linear-gradient(135deg, #ff6a88, #ff99ac); }
.slide:nth-of-type(4) { background: linear-gradient(135deg, #ff8fa3, #ff758c); }

.active {
  display: flex;
}

/* heading */
h1 {
  font-family: 'Pacifico', cursive;
  font-size: 36px;
}

/* glowing name */
.name {
  text-shadow: 0 0 15px #fff, 0 0 40px #ff4b7d;
}

/* message box */
p {
  max-width: 800px;
  line-height: 1.6;
  white-space: pre-line;
  background: rgba(255,255,255,0.2);
  padding: 15px;
  border-radius: 15px;
  backdrop-filter: blur(8px);
}

/* buttons */
button {
  margin-top: 20px;
  padding: 12px 25px;
  border-radius: 25px;
  border: none;
  background: white;
  color: #ff4b7d;
  font-weight: bold;
  cursor: pointer;
}

/* floating hearts */
.float {
  position: fixed;
  font-size: 20px;
  animation: floatUp linear infinite;
}

@keyframes floatUp {
  from { transform: translateY(100vh); }
  to { transform: translateY(-10vh); }
}

/* heart burst */
.burst {
  position: fixed;
  font-size: 18px;
  pointer-events: none;
  animation: burst 1s forwards;
}

@keyframes burst {
  to {
    transform: translate(70px, -90px);
    opacity: 0;
  }
}
</style>
</head>

<body>

<!-- PASSWORD LOCK -->
